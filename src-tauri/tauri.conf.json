{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PenManager",
  "version": "0.1.1",
  "identifier": "io.github.lyrecoul.penmanager",
  "build": {
    "beforeDevCommand": "npm run prepare:adb && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run prepare:adb && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PenManager",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/adb"],
    "shortDescription": "Youdao Dictionary Pen manager",
    "category": "Utility"
  }
}
